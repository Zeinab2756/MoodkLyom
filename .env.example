APP_ENV=development
DATABASE_URL=sqlite:///./data/moodaklyom.db
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of frontend origins allowed to call the API.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Transcription backends
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AUDIO_TRANSCRIPTION_URL=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_WHISPER_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01
TRANSCRIPTION_FALLBACK_TEXT=
FASTER_WHISPER_MODEL=tiny
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

# Text emotion
EMOTION_MODEL_NAME=bhadresh-savani/bert-base-uncased-emotion
EMOTION_API_URL=
EMOTION_API_TIMEOUT=30

# Acoustic emotion
ACOUSTIC_EMOTION_MODEL_NAME=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition
ACOUSTIC_EMOTION_SAMPLE_RATE=16000

# Fusion
FUSION_AUDIO_WEIGHT=0.6
FUSION_TEXT_WEIGHT=0.4

# Hugging Face cache
HF_HOME=/hf-cache
HF_HUB_DISABLE_SYMLINKS_WARNING=1
